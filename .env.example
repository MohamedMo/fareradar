# ══════════════════════════════════════════════════════════════
# FareRadar Free — Configuration
# ══════════════════════════════════════════════════════════════
# Every API key here is FREE. Total monthly cost: £0.

# ── API Keys (all free tiers) ────────────────────────────────

# 1. SerpAPI — Google Travel Explore (250 free queries/month)
#    Sign up: https://serpapi.com (no credit card needed)
SERPAPI_KEY=your_serpapi_key

# 2. Amadeus Self-Service (2,000 free calls/month)
#    Sign up: https://developers.amadeus.com
AMADEUS_API_KEY=your_amadeus_key
AMADEUS_API_SECRET=your_amadeus_secret

# 3. Kiwi Tequila (free registration)
#    Sign up: https://tequila.kiwi.com
KIWI_API_KEY=your_kiwi_key

# 4. Telegram Bot (free, for instant alerts)
#    Message @BotFather on Telegram → /newbot → copy the token
#    Message @userinfobot → get your chat ID
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# 5. Discord webhook (free, alternative / addition to Telegram)
#    In your Discord server: Server Settings → Integrations →
#    Webhooks → New Webhook → Copy URL.
#    One webhook for public deals, optionally a second for the
#    review queue. If you leave the review one blank it falls back
#    to the public webhook.
DISCORD_WEBHOOK_URL=
DISCORD_REVIEW_WEBHOOK_URL=

# ── Your Airports ────────────────────────────────────────────
# Comma-separated IATA codes for your departure airports
# UK:
ORIGINS=LHR,LGW,STN,MAN,EDI,BHX,BRS,LTN
# US:
# ORIGINS=JFK,EWR,LAX,SFO,ORD,BOS,MIA,SEA

# ── Thresholds ───────────────────────────────────────────────
ANOMALY_PCT=35          # % below average to flag as deal
ERROR_FARE_PCT=60       # % below average to classify as error fare
MIN_DATAPOINTS=3        # minimum price history before analysis

# ── Daily API Budgets ────────────────────────────────────────
# Auto-enforced. Scanner stops calling an API when budget is hit.
SERPAPI_DAILY=8          # 250/month ÷ 30
AMADEUS_DAILY=60         # 2000/month ÷ 30
KIWI_DAILY=100           # estimated free tier

# ── Database ─────────────────────────────────────────────────
DB_PATH=fareradar_v2.db
